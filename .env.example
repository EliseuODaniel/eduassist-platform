COMPOSE_PROJECT_NAME=eduassist-platform
APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=eduassist
POSTGRES_PASSWORD=eduassist
POSTGRES_DB=eduassist
POSTGRES_KEYCLOAK_DB=keycloak
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://eduassist:eduassist@postgres:5432/eduassist
DATABASE_URL_LOCAL=postgresql://eduassist:eduassist@localhost:5432/eduassist
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_DOCUMENTS_COLLECTION=school_documents
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DOCUMENTS=documents
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_HOST=http://keycloak:8080
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=eduassist
KEYCLOAK_WEB_CLIENT_ID=eduassist-web
KEYCLOAK_ALLOWED_CLIENTS=eduassist-web,eduassist-cli
OPA_URL=http://opa:8181
OTEL_ENABLED=true
OTEL_SERVICE_NAMESPACE=eduassist-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
INTERNAL_API_TOKEN=dev-internal-token
ALLOW_TEST_IDENTITY_OVERRIDES=true
TELEGRAM_LINK_TTL_MINUTES=15
TELEGRAM_BOT_USERNAME=
ADMIN_WEB_PUBLIC_URL=http://localhost:3000

API_CORE_PORT=8001
AI_ORCHESTRATOR_PORT=8002
TELEGRAM_GATEWAY_PORT=8003
ADMIN_WEB_PORT=3000

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro
GRAPH_RAG_ENABLED=false
DOCUMENT_PIPELINE_BACKEND=markdown
DOCUMENT_CORPUS_DIR=/workspace/data/corpus
DOCUMENT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
WORKER_BOOTSTRAP_DOCUMENTS=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me

POSTGRES_IMAGE=postgres:17
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:latest
MINIO_IMAGE=minio/minio:latest
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.1
OPA_IMAGE=openpolicyagent/opa:latest-static
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.122.1
TEMPO_IMAGE=grafana/tempo:2.7.2
TEMPO_PORT=3200
LOKI_IMAGE=grafana/loki:3.5.5
PROMTAIL_IMAGE=grafana/promtail:3.5.5
LOKI_PORT=3100
GRAFANA_IMAGE=grafana/grafana:11.6.0
GRAFANA_PORT=3004
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
PYTHON_BASE_IMAGE=ghcr.io/astral-sh/uv:python3.12-bookworm-slim
NODE_BASE_IMAGE=node:24-bookworm-slim
FOUNDATION_SEED=20260323
