      "id": 1,
      "options": {
        "content": "# EduAssist metrics\n\nEste dashboard acompanha o baseline operacional de `policy`, `retrieval`, `handoff` e `orquestracao` a partir das metricas OTEL exportadas para `Prometheus`.\n\nLeitura recomendada:\n\n1. confira negacoes e permissoes de `policy`\n2. confira volume e latencia de `retrieval`\n3. confira criacao de `handoffs`\n4. confira distribuicao e latencia do `ai-orchestrator`\n",
        "mode": "markdown"
      },
      "pluginVersion": "11.6.0",
      "title": "Visao geral",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(eduassist_policy_decisions_total{allow=\"true\"}[15m]))",
